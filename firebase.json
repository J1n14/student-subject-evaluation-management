{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase/**",
      "package.json",
      "package-lock.json",
      "README.md",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": []
  }
}
